#!/usr/bin/env bash
# Launcher for the myco server (mycod).
# Resolves to the script's own directory so it works from anywhere.

set -e
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DIR/server"

if [ ! -d node_modules ]; then
  echo "[mycod] First run — installing dependencies…"
  npm install
fi

exec node src/index.js "$@"
